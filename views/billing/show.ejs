<div class="page-head"><h1>Bill <%= bill.bill_no %></h1><button onclick="window.print()" class="btn">Print</button></div><div class="grid stats"><div><b>Rs. <%= bill.total %></b><span>Total</span></div><div><b>Rs. <%= bill.paid_amount %></b><span>Paid</span></div><div><b>Rs. <%= bill.balance %></b><span>Balance</span></div><div><b><%= bill.status %></b><span>Status</span></div></div><h2>Items</h2><table><tr><th>Type</th><th>Description</th><th>Qty</th><th>Unit</th><th>Total</th></tr><% items.forEach(i=>{ %><tr><td><%= i.item_type %></td><td><%= i.description %></td><td><%= i.quantity %></td><td>Rs. <%= i.unit_price %></td><td>Rs. <%= i.line_total %></td></tr><% }) %></table><form method="post" action="/billing/<%= bill.id %>/items" class="inline-form"><select name="item_type"><option>service</option><option>medicine</option><option>lab</option></select><input name="description" required placeholder="description"><input name="quantity" type="number" value="1" min="1"><input name="unit_price" type="number" step="0.01" required placeholder="price"><button>Add Item</button></form><h2>Payments</h2><table><tr><th>Amount</th><th>Method</th><th>Received By</th><th>Date</th><th>Notes</th></tr><% payments.forEach(p=>{ %><tr><td>Rs. <%= p.amount %></td><td><%= p.method %></td><td><%= p.received_by_name||'' %></td><td><%= new Date(p.paid_at).toLocaleString() %></td><td><%= p.notes||'' %></td></tr><% }) %></table><form method="post" action="/billing/<%= bill.id %>/payments" class="inline-form"><input name="amount" type="number" step="0.01" required placeholder="amount"><select name="method"><option>cash</option><option>card</option><option>bank</option><option>insurance</option></select><input name="notes" placeholder="notes"><button>Record Payment</button></form>