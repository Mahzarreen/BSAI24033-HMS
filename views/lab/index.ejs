<div class="page-head"><h1>Lab Management</h1><a class="btn" href="/lab/request">New Lab Request</a></div><form class="search"><select name="status"><option value="">All</option><% ['requested','sample_collected','completed','cancelled'].forEach(s=>{ %><option <%= status===s?'selected':'' %>><%= s %></option><% }) %></select><button>Filter</button></form><table><tr><th>Patient</th><th>Doctor</th><th>Test</th><th>Price</th><th>Status/Result</th></tr><% requests.forEach(r=>{ %><tr><td><%= r.patient_name %></td><td><%= r.doctor_name %></td><td><%= r.test_name %></td><td>Rs. <%= r.price %></td><td><form method="post" action="/lab/<%= r.id %>/update"><select name="status"><% ['requested','sample_collected','completed','cancelled'].forEach(s=>{ %><option <%= r.status===s?'selected':'' %>><%= s %></option><% }) %></select><input name="result_value" value="<%= r.result_value||'' %>" placeholder="result"><input name="result_notes" value="<%= r.result_notes||'' %>" placeholder="notes"><button>Save</button></form></td></tr><% }) %></table>