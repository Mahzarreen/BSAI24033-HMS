<h1>Request Lab Test</h1><form method="post" action="/lab/request" class="grid-form"><label>Appointment optional<select name="appointment_id"><option value="">No linked appointment</option><% appointments.forEach(a=>{ %><option value="<%= a.id %>"><%= a.patient_name %> with <%= a.doctor_name %> - <%= new Date(a.scheduled_at).toLocaleString() %></option><% }) %></select></label><label>Patient<select name="patient_id" required><% patients.forEach(p=>{ %><option value="<%= p.id %>"><%= p.mrn %> - <%= p.full_name %></option><% }) %></select></label><label>Doctor<select name="doctor_id" required><% doctors.forEach(d=>{ %><option value="<%= d.id %>"><%= d.name %></option><% }) %></select></label><label>Test<select name="lab_test_id" required><% tests.forEach(t=>{ %><option value="<%= t.id %>"><%= t.test_name %> - Rs. <%= t.price %></option><% }) %></select></label><button class="primary">Create Lab Request</button></form>