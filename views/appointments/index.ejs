<div class="page-head"><h1>Appointments</h1><a class="btn" href="/appointments/new">Schedule Appointment</a></div><form class="search"><select name="doctor"><option value="">All doctors</option><% doctors.forEach(d=>{ %><option value="<%= d.id %>" <%= String(filters.doctor)===String(d.id)?'selected':'' %>><%= d.name %></option><% }) %></select><select name="status"><option value="">All status</option><% ['scheduled','completed','cancelled','no_show'].forEach(s=>{ %><option <%= filters.status===s?'selected':'' %>><%= s %></option><% }) %></select><input type="date" name="date" value="<%= filters.date||'' %>"><button>Filter</button></form><table><tr><th>Date/Time</th><th>Patient</th><th>MRN</th><th>Doctor</th><th>Status</th><th>Update</th></tr><% appointments.forEach(a=>{ %><tr><td><%= new Date(a.scheduled_at).toLocaleString() %></td><td><%= a.patient_name %></td><td><%= a.mrn %></td><td><%= a.doctor_name %></td><td><%= a.status %></td><td><form method="post" action="/appointments/<%= a.id %>/status"><select name="status"><% ['scheduled','completed','cancelled','no_show'].forEach(s=>{ %><option <%= a.status===s?'selected':'' %>><%= s %></option><% }) %></select><input name="notes" placeholder="notes"><button>Save</button></form></td></tr><% }) %></table>