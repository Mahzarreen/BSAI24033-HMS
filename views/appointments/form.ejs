<h1>Schedule Appointment</h1><form method="post" action="/appointments" class="grid-form"><label>Patient<select name="patient_id" required><% patients.forEach(p=>{ %><option value="<%= p.id %>"><%= p.mrn %> - <%= p.full_name %></option><% }) %></select></label><label>Doctor<select name="doctor_id" required><% doctors.forEach(d=>{ %><option value="<%= d.id %>"><%= d.name %> - <%= d.specialization %> (Rs. <%= d.consultation_fee %>)</option><% }) %></select></label><label>Time<input type="datetime-local" name="scheduled_at" required></label><label>Duration<input type="number" name="duration_minutes" value="30" min="10" max="240"></label><label class="wide">Reason<textarea name="reason"></textarea></label><button class="primary">Create Appointment + Bill</button></form><div class="panel">Database rule prevents double booking for the same doctor and overlapping time.</div>