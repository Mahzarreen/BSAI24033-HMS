<h1>Dashboard</h1><% if(user.role==='admin'){ const s=data.summary||{}; %><div class="grid stats"><div><b><%= s.total_patients %></b><span>Patients</span></div><div><b><%= s.today_appointments %></b><span>Today Appointments</span></div><div><b><%= s.pending_lab_requests %></b><span>Pending Lab</span></div><div><b>Rs. <%= s.outstanding_amount %></b><span>Outstanding</span></div></div><h2>Recent Schedule</h2><%- include('partials/schedule_table',{appointments:data.recent}) %><% } else if(user.role==='doctor'){ %><h2>My Schedule</h2><%- include('partials/schedule_table',{appointments:data.schedule}) %><h2>My Lab Requests</h2><table><tr><th>Patient</th><th>Test</th><th>Status</th><th>Requested</th></tr><% data.pendingLabs.forEach(r=>{ %><tr><td><%= r.full_name %></td><td><%= r.test_name %></td><td><%= r.status %></td><td><%= new Date(r.requested_at).toLocaleString() %></td></tr><% }) %></table><% } else { %><h2>Today Schedule</h2><%- include('partials/schedule_table',{appointments:data.today}) %><h2>Recent Bills</h2><%- include('partials/bills_table',{bills:data.bills}) %><% } %>