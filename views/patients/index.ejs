<div class="page-head"><h1>Patients</h1><a class="btn" href="/patients/new">Register Patient</a></div><form class="search"><input name="q" value="<%= q||'' %>" placeholder="Search by name, MRN, phone"><button>Search</button></form><table><tr><th>MRN</th><th>Name</th><th>Gender</th><th>Phone</th><th>Blood</th><th></th></tr><% patients.forEach(p=>{ %><tr><td><%= p.mrn %></td><td><%= p.full_name %></td><td><%= p.gender %></td><td><%= p.phone||'' %></td><td><%= p.blood_group||'' %></td><td><a href="/patients/<%= p.id %>">Open</a></td></tr><% }) %></table>