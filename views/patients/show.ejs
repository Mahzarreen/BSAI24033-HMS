<div class="page-head"><h1><%= patient.full_name %></h1><a class="btn" href="/patients/<%= patient.id %>/edit">Edit</a></div><div class="panel"><p><b>MRN:</b> <%= patient.mrn %> | <b>Phone:</b> <%= patient.phone||'' %> | <b>Blood:</b> <%= patient.blood_group||'' %></p><p><b>Medical History:</b> <%= patient.medical_history||'None' %></p><p><b>Allergies:</b> <%= patient.allergies||'None' %></p></div><h2>Appointments</h2><%- include('../partials/schedule_table',{appointments}) %><h2>Lab Requests</h2><table><tr><th>Test</th><th>Doctor</th><th>Status</th><th>Result</th></tr><% labs.forEach(l=>{ %><tr><td><%= l.test_name %></td><td><%= l.doctor_name %></td><td><%= l.status %></td><td><%= l.result_value||'' %></td></tr><% }) %></table><h2>Bills</h2><%- include('../partials/bills_table',{bills}) %>