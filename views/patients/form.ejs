<h1><%= title %></h1><form method="post" action="<%= patient.id?'/patients/'+patient.id:'/patients' %>" class="grid-form"><label>Name<input name="full_name" required value="<%= patient.full_name||'' %>"></label><label>Gender<select name="gender"><option <%= patient.gender==='male'?'selected':'' %> value="male">Male</option><option <%= patient.gender==='female'?'selected':'' %> value="female">Female</option><option <%= patient.gender==='other'?'selected':'' %> value="other">Other</option></select></label><label>DOB<input type="date" name="date_of_birth" value="<%= patient.date_of_birth ? String(patient.date_of_birth).slice(0,10) : '' %>"></label><label>Phone<input name="phone" value="<%= patient.phone||'' %>"></label><label>Email<input name="email" value="<%= patient.email||'' %>"></label><label>Blood Group<input name="blood_group" value="<%= patient.blood_group||'' %>"></label><label>Emergency Contact<input name="emergency_contact" value="<%= patient.emergency_contact||'' %>"></label><label class="wide">Address<textarea name="address"><%= patient.address||'' %></textarea></label><label class="wide">Medical History<textarea name="medical_history"><%= patient.medical_history||'' %></textarea></label><label class="wide">Allergies<textarea name="allergies"><%= patient.allergies||'' %></textarea></label><button class="primary">Save Patient</button></form>