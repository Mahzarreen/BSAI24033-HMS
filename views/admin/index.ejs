<h1>Administration</h1><section class="panel"><h2>Create User / Doctor</h2><form method="post" action="/admin/users" class="grid-form"><input name="name" required placeholder="Name"><input name="email" type="email" required placeholder="Email"><input name="password" required placeholder="Password"><select name="role"><option>staff</option><option>doctor</option><option>admin</option></select><input name="phone" placeholder="Phone"><select name="department_id"><option value="">Department</option><% depts.forEach(d=>{ %><option value="<%= d.id %>"><%= d.name %></option><% }) %></select><input name="specialization" placeholder="Doctor specialization"><input name="consultation_fee" type="number" placeholder="Fee"><input name="room_no" placeholder="Room"><button>Create</button></form></section><section class="panel"><h2>Departments</h2><form method="post" action="/admin/departments" class="inline-form"><input name="name" required placeholder="Name"><input name="description" placeholder="Description"><button>Save</button></form><ul><% depts.forEach(d=>{ %><li><b><%= d.name %></b> — <%= d.description||'' %></li><% }) %></ul></section><section class="panel"><h2>Lab Tests</h2><form method="post" action="/admin/tests" class="inline-form"><input name="test_name" required placeholder="Test name"><input name="price" type="number" step="0.01" required placeholder="Price"><input name="normal_range" placeholder="Normal range"><input name="description" placeholder="Description"><button>Save</button></form><table><tr><th>Test</th><th>Price</th><th>Range</th></tr><% tests.forEach(t=>{ %><tr><td><%= t.test_name %></td><td>Rs. <%= t.price %></td><td><%= t.normal_range||'' %></td></tr><% }) %></table></section><h2>Users</h2><table><tr><th>Name</th><th>Email</th><th>Role</th><th>Active</th></tr><% users.forEach(u=>{ %><tr><td><%= u.name %></td><td><%= u.email %></td><td><%= u.role %></td><td><%= u.is_active %></td></tr><% }) %></table><h2>Audit Logs</h2><table><tr><th>Table</th><th>Record</th><th>Action</th><th>Time</th></tr><% audit.forEach(a=>{ %><tr><td><%= a.table_name %></td><td><%= a.record_id %></td><td><%= a.action %></td><td><%= new Date(a.changed_at).toLocaleString() %></td></tr><% }) %></table>